# ===========================================
# Lucir Editorial — Ortam Değişkenleri
# ===========================================
# Frontend: .env.local kopyala
# Vercel: Dashboard → Settings → Environment Variables (server key'ler)

# --- Supabase (opsiyonel — paused olursa localStorage devam eder) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase admin — SADECE Vercel server (asla frontend'e koyma!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Site URL (iyzico callback için — Vercel'de otomatik) ---
SITE_URL=https://your-domain.vercel.app

# --- Ödeme: Havale/EFT (ücretsiz, varsayılan) ---
VITE_BANK_IBAN=TR00 0000 0000 0000 0000 0000 00
VITE_BANK_ACCOUNT_HOLDER=LUCIR ARCHITECTURAL FASHION

# --- Ödeme: iyzico (Türkiye — sandbox ücretsiz) ---
# https://merchant.iyzipay.com → Sandbox API keys
IYZICO_API_KEY=sandbox-xxx
IYZICO_SECRET_KEY=sandbox-xxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_USD_TRY_RATE=36
VITE_IYZICO_ENABLED=true
# Lokal: boş bırak (vite proxy). Production: boş veya site URL
VITE_API_URL=

# --- Ödeme: Lemon Squeezy (opsiyonel) ---
VITE_LEMONSQUEEZY_CHECKOUT_URL=https://lucir.lemonsqueezy.com/checkout/buy/xxxxx

# --- Ödeme: PayPal (opsiyonel) ---
VITE_PAYPAL_CHECKOUT_URL=https://paypal.me/lucir/{AMOUNT}?note={ORDER_ID}

# --- E-posta: Web3Forms (ücretsiz 250/ay) ---
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_key
